generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  TEACHER
  STUDENT
}

model User {
  id                  Int       @id @default(autoincrement())
  email               String    @unique
  password            String
  name                String
  role                Role      @default(STUDENT)
  registrationNumber  String?   @unique
  mustChangePassword  Boolean   @default(false)
  
  // Relations
  activityFolders ActivityFolder[]
  modules         Module[]         @relation("TeacherModules")
  enrollments     StudentEnrollment[]
  submissions     Submission[]
  
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

model Semester {
  id        Int       @id @default(autoincrement())
  name      String    // e.g., "Fall 2024"
  
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

model Module {
  id                Int      @id @default(autoincrement())
  name              String
  description       String?
  
  semesterLevel     Int      @default(1)
  department        String   @default("BSCS")
  section           String   @default("A")
  academicYear      Int      @default(2026)
  academicSemester  String   @default("Fall")
  
  courseId          Int?
  course            Course?  @relation(fields: [courseId], references: [id])
  
  teacherId         Int?
  teacher           User?    @relation("TeacherModules", fields: [teacherId], references: [id])
  
  enrolledStudents  StudentEnrollment[]
  
  outlineName       String?
  outlineUrl        String?
  
  registeredStudentsName String?
  registeredStudentsUrl  String?
  
  lectureProgressName    String?
  lectureProgressUrl     String?
  
  recapSheetName         String?
  recapSheetUrl          String?
  
  fcarName               String?
  fcarUrl                String?
  
  materials         Material[]
  assessments       Assessment[]
  announcements     Announcement[]
  
  
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

// Explicit Join Table for many-to-many (User to Module)
model StudentEnrollment {
  id         Int      @id @default(autoincrement())
  studentId  Int
  moduleId   Int
  
  student    User     @relation(fields: [studentId], references: [id], onDelete: Cascade)
  module     Module   @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  
  enrolledAt DateTime @default(now())

  @@unique([studentId, moduleId])
}

model Material {
  id          Int      @id @default(autoincrement())
  title       String
  fileUrl     String
  
  moduleId    Int
  module      Module   @relation(fields: [moduleId], references: [id])
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model ActivityFolder {
  id          Int      @id @default(autoincrement())
  title       String
  description String?
  
  studentId   Int
  student     User     @relation(fields: [studentId], references: [id])
  
  docs        FolderDoc[]
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model FolderDoc {
  id               Int            @id @default(autoincrement())
  name             String
  fileUrlOrLink    String

  activityFolderId Int
  activityFolder   ActivityFolder @relation(fields: [activityFolderId], references: [id])
  
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
}

model Course {
  id            Int      @id @default(autoincrement())
  code          String   @unique
  name          String
  prerequisite  String?
  creditHours   Int
  
  modules       Module[]
  
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

enum AssessmentType {
  ASSIGNMENT
  QUIZ
  MID_TERM
  FINAL_TERM
}

model Assessment {
  id        Int            @id @default(autoincrement())
  type      AssessmentType
  sequenceNo Int?          // Used for Assignment 1-4, Quiz 1-4. Null for Mid/Final.
  marks     Float
  startDate String
  endDate   String
  time      String
  fileUrl   String
  fileName  String

  solutionFileName       String?
  solutionShowToStudent  Boolean @default(false)
  
  bestFileName           String?
  avgFileName            String?
  worstFileName          String?

  title                  String?
  isAssigned             Boolean @default(false)

  moduleId  Int
  module    Module         @relation(fields: [moduleId], references: [id])
  submissions Submission[]

  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt
}

model Announcement {
  id        Int      @id @default(autoincrement())
  title     String
  content   String   @db.Text
  
  moduleId  Int
  module    Module   @relation(fields: [moduleId], references: [id])
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Submission {
  id            Int      @id @default(autoincrement())
  studentId     Int
  student       User     @relation(fields: [studentId], references: [id], onDelete: Cascade)
  
  assessmentId  Int
  assessment    Assessment @relation(fields: [assessmentId], references: [id], onDelete: Cascade)
  
  fileName      String?
  fileUrl       String?
  
  marksObtained Float?    // For teacher to grade
  feedback      String?   @db.Text
  
  submittedAt   DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([studentId, assessmentId])
}
